---
export interface FAQItem { question: string; answer: string; }
const { faqs, lang = 'es' } = Astro.props as { faqs: FAQItem[]; lang?: string };
const heading = lang === 'en' ? 'Frequently Asked Questions' : 'Preguntas frecuentes';
---
<div class="faq-section">
  <h2>{heading}</h2>
  <div class="faq-list">
    {faqs.map((faq, idx) => (
      <details class="faq-item" open={idx === 0 ? true : false}>
        <summary>{faq.question}</summary>
        <div class="faq-answer" set:html={faq.answer}></div>
      </details>
    ))}
  </div>
</div>

<style>
  .faq-section { margin: 2.5rem 0; }
  .faq-section h2 { font-size: 1.5rem; margin-bottom: 1.5rem; }
  .faq-item { background: #f9fafb; border-radius: 0.75rem; margin-bottom: 1rem; padding: 0.5rem 1rem; border: 1px solid #e5e7eb; }
  .faq-item summary { font-weight: 600; cursor: pointer; padding: 0.5rem 0; }
  .faq-answer { padding: 0.5rem 0 1rem; color: #4b5563; line-height: 1.5; }
</style>