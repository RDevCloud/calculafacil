---
export interface Props {
  format: 'horizontal' | 'vertical' | 'banner';
  className?: string;
}
const { format = 'horizontal', className = '' } = Astro.props;

const adClass = {
  horizontal: 'ad-horizontal',
  vertical:   'ad-vertical',
  banner:     'ad-banner',
}[format];
---

<div class={`ad-slot ${adClass} ${className}`} data-format={format}>
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-6695699939765081"
    data-ad-slot="auto"
    data-ad-format="auto"
    data-full-width-responsive="true"
  ></ins>
</div>

<script>
  // Push each ad unit when component mounts
  (window.adsbygoogle = window.adsbygoogle || []).push({});
</script>

<style>
  .ad-slot { display: flex; justify-content: center; align-items: center; margin: 1.25rem auto; overflow: hidden; }
  .ad-horizontal { width: 100%; min-height: 90px; }
  .ad-vertical   { width: 300px; min-height: 250px; }
  .ad-banner     { width: 100%; min-height: 90px; }
  @media (max-width: 728px) { .ad-vertical { width: 100%; } }
</style>