---
export interface Props {
  format: 'horizontal' | 'vertical' | 'banner';
  className?: string;
}
const { format = 'horizontal', className = '' } = Astro.props;
const sizes = {
  horizontal: { width: 728, height: 90, class: 'ad-horizontal' },
  vertical: { width: 300, height: 250, class: 'ad-vertical' },
  banner: { width: 970, height: 90, class: 'ad-banner' }
};
const size = sizes[format];
---
<div class={`ad-slot ${size.class} ${className}`} data-format={format}>
  <div class="ad-placeholder">
    <span>Publicidad</span>
    <small>Espacio para AdSense</small>
  </div>
  <!-- Código real de AdSense (comentado) -->
  <!-- <ins class="adsbygoogle" style="display:block" data-ad-client="ca-pub-xxxxxxxxxx" data-ad-slot="1234567890" data-ad-format="auto"></ins> -->
</div>

<style>
  .ad-slot { background: #f3f4f6; border: 1px dashed #d1d5db; display: flex; justify-content: center; align-items: center; margin: 1rem auto; text-align: center; }
  .ad-horizontal { min-width: 728px; min-height: 90px; max-width: 100%; }
  .ad-vertical { width: 300px; height: 250px; }
  .ad-banner { width: 970px; height: 90px; max-width: 100%; }
  .ad-placeholder { color: #6b7280; font-size: 0.75rem; display: flex; flex-direction: column; }
  @media (max-width: 728px) { .ad-horizontal { min-width: auto; width: 100%; height: auto; padding: 1rem 0; } }
</style>