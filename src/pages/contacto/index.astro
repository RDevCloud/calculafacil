---
import BaseLayout from '../../layouts/BaseLayout.astro';
---
<BaseLayout title="Contacto" description="Contacta con el equipo de CalculaFácil para sugerencias, reportar errores o proponer nuevas herramientas.">
  <div class="static-page">
    <h1>Contacto</h1>
    <p class="lead">¿Tienes una pregunta, sugerencia o encontraste un error? Nos encantaría saber de ti.</p>

    <div class="contact-card">
      <h2>📬 Envíanos un mensaje</h2>
      <form id="contact-form" class="contact-form">
        <label for="nombre">Tu nombre</label>
        <input type="text" id="nombre" name="nombre" placeholder="Ej: María García" required />

        <label for="email">Correo electrónico</label>
        <input type="email" id="email" name="email" placeholder="tu@correo.com" required />

        <label for="asunto">Asunto</label>
        <select id="asunto" name="asunto">
          <option value="sugerencia">Sugerencia de herramienta</option>
          <option value="error">Reportar un error</option>
          <option value="otro">Otro</option>
        </select>

        <label for="mensaje">Mensaje</label>
        <textarea id="mensaje" name="mensaje" rows="5" placeholder="Escribe tu mensaje aquí..." required></textarea>

        <button type="submit" id="submit-btn">Enviar mensaje</button>
        <div id="form-msg" class="form-msg hidden"></div>
      </form>
    </div>

    <div class="contact-info">
      <h2>🕐 Tiempo de respuesta</h2>
      <p>Revisamos los mensajes regularmente. Normalmente respondemos en un plazo de 24-48 horas en días hábiles.</p>
    </div>
  </div>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const msg  = document.getElementById('form-msg');
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if (msg) {
      msg.textContent = '✅ ¡Gracias! Tu mensaje ha sido recibido. Te responderemos pronto.';
      msg.className = 'form-msg success';
    }
    form.reset();
  });
</script>

<style>
  .static-page { max-width: 700px; margin: 0 auto; padding: 2rem 0; }
  .static-page h1 { font-size: 2rem; margin-bottom: 1rem; color: #111827; }
  .static-page h2 { font-size: 1.25rem; margin: 2rem 0 0.75rem; color: #1e3a8a; }
  .static-page p { color: #374151; line-height: 1.8; }
  .lead { font-size: 1.1rem; color: #4b5563; font-style: italic; margin-bottom: 2rem; }
  .contact-card { background: #fff; border-radius: 1rem; padding: 2rem; box-shadow: 0 2px 8px rgba(0,0,0,0.08); margin-bottom: 2rem; }
  .contact-form label { display: block; font-weight: 600; margin-bottom: 0.3rem; color: #374151; }
  .contact-form input, .contact-form select, .contact-form textarea {
    width: 100%; padding: 0.65rem 0.9rem; border: 1px solid #d1d5db; border-radius: 0.5rem;
    font-size: 1rem; margin-bottom: 1.2rem; box-sizing: border-box; font-family: inherit;
  }
  .contact-form input:focus, .contact-form textarea:focus, .contact-form select:focus {
    outline: none; border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.1);
  }
  .contact-form button {
    background: #1e3a8a; color: white; font-size: 1rem; font-weight: 600;
    padding: 0.75rem 2rem; border: none; border-radius: 0.5rem; cursor: pointer; transition: background 0.2s;
  }
  .contact-form button:hover { background: #2563eb; }
  .form-msg { margin-top: 1rem; padding: 0.75rem 1rem; border-radius: 0.5rem; font-size: 0.95rem; }
  .form-msg.success { background: #ecfdf5; color: #065f46; border: 1px solid #a7f3d0; }
  .form-msg.hidden { display: none; }
</style>
