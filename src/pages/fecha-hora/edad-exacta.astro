---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolFormShell from '../../components/ToolFormShell.astro';
import { generateTitle, generateDescription } from '../../utils/seo';

const toolName = 'Edad exacta';
const slug = 'edad-exacta';
const category = 'fecha-hora';
const title = generateTitle(toolName);
const description = generateDescription(toolName, 'tu edad exacta en años, meses y días');
const canonical = `https://calculafacilito.netlify.app/fecha-hora/${slug}/`;
const breadcrumbItems = [
  { name: 'Fecha y hora', url: '/fecha-hora/' },
  { name: toolName }
];
const faqs = [
  { question: '¿Cómo calculo mi edad exacta?', answer: 'Ingresa tu fecha de nacimiento y la calculadora determinará tus años, meses y días exactos hasta hoy.' },
  { question: '¿Cuándo cumplo el próximo año?', answer: 'La calculadora también muestra los días que faltan para tu próximo cumpleaños.' },
];
---

<ToolLayout title={title} description={description} canonical={canonical} breadcrumbItems={breadcrumbItems} toolName={toolName} toolSlug={slug} category={category} faqs={faqs}>
  <div slot="intro">
    <p>Calcula tu edad exacta en años, meses y días a partir de tu fecha de nacimiento.</p>
  </div>
  <div slot="form">
    <ToolFormShell toolName={toolName}>
      <div slot="inputs">
        <label>Fecha de nacimiento:</label>
        <input type="date" id="nacimiento" required />
      </div>
    </ToolFormShell>
  </div>
  <div slot="explanation">
    <h2>¿Cómo funciona?</h2>
    <p>Compara tu fecha de nacimiento con la fecha actual para calcular tu edad exacta incluyendo años, meses y días.</p>
  </div>
</ToolLayout>

<script>
  document.getElementById('calc-btn')?.addEventListener('click', () => {
    const nac = new Date((document.getElementById('nacimiento') as HTMLInputElement).value);
    const hoy = new Date();
    const div = document.getElementById('result');
    if (!div || isNaN(nac.getTime())) return;
    let years = hoy.getFullYear() - nac.getFullYear();
    let months = hoy.getMonth() - nac.getMonth();
    let days = hoy.getDate() - nac.getDate();
    if (days < 0) { months--; days += new Date(hoy.getFullYear(), hoy.getMonth(), 0).getDate(); }
    if (months < 0) { years--; months += 12; }
    const bday = new Date(hoy.getFullYear(), nac.getMonth(), nac.getDate());
    if (bday < hoy) bday.setFullYear(hoy.getFullYear() + 1);
    const daysLeft = Math.round((bday.getTime() - hoy.getTime()) / (1000 * 60 * 60 * 24));
    div.innerHTML = `<strong>${years} años, ${months} meses y ${days} días</strong><br><small>Próximo cumpleaños en ${daysLeft} día(s) 🎂</small>`;
  });
</script>
