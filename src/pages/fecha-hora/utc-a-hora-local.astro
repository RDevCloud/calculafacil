---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolFormShell from '../../components/ToolFormShell.astro';
import { generateTitle, generateDescription } from '../../utils/seo';

const toolName = 'UTC a hora local';
const slug = 'utc-a-hora-local';
const category = 'fecha-hora';
const title = generateTitle(toolName);
const description = generateDescription(toolName, 'convertir cualquier hora UTC a tu hora local');
const canonical = `https://calculafacilito.netlify.app/fecha-hora/${slug}/`;
const breadcrumbItems = [
  { name: 'Fecha y hora', url: '/fecha-hora/' },
  { name: toolName }
];
const faqs = [
  { question: '¿Qué es UTC?', answer: 'UTC (Tiempo Universal Coordinado) es el estándar de tiempo base del mundo. Tu hora local se expresa como UTC ± offset.' },
  { question: '¿Cómo sé mi UTC offset?', answer: 'México (CST) es UTC-6, España (CET) es UTC+1 en invierno y UTC+2 en verano.' },
];
---

<ToolLayout title={title} description={description} canonical={canonical} breadcrumbItems={breadcrumbItems} toolName={toolName} toolSlug={slug} category={category} faqs={faqs}>
  <div slot="intro">
    <p>Convierte cualquier hora UTC a tu zona horaria local seleccionando tu offset UTC.</p>
  </div>
  <div slot="form">
    <ToolFormShell toolName={toolName}>
      <div slot="inputs">
        <label>Hora UTC (HH:MM):</label>
        <input type="time" id="hora-utc" required />
        <label>Tu offset UTC:</label>
        <select id="offset">
          <option value="-12">UTC-12</option>
          <option value="-11">UTC-11</option>
          <option value="-10">UTC-10</option>
          <option value="-9">UTC-9</option>
          <option value="-8">UTC-8 (PST)</option>
          <option value="-7">UTC-7 (MST/PDT)</option>
          <option value="-6" selected>UTC-6 (CST/MDT)</option>
          <option value="-5">UTC-5 (EST/CDT)</option>
          <option value="-4">UTC-4 (EDT/AST)</option>
          <option value="-3">UTC-3</option>
          <option value="0">UTC+0 (GMT)</option>
          <option value="1">UTC+1 (CET)</option>
          <option value="2">UTC+2 (CEST)</option>
          <option value="3">UTC+3</option>
          <option value="5.5">UTC+5:30 (IST)</option>
          <option value="8">UTC+8 (CST China)</option>
          <option value="9">UTC+9 (JST)</option>
        </select>
      </div>
    </ToolFormShell>
  </div>
  <div slot="explanation">
    <h2>¿Cómo funciona?</h2>
    <p>Suma el offset de tu zona horaria a la hora UTC para obtener tu hora local.</p>
  </div>
</ToolLayout>

<script>
  document.getElementById('calc-btn')?.addEventListener('click', () => {
    const val    = (document.getElementById('hora-utc') as HTMLInputElement).value;
    const offset = parseFloat((document.getElementById('offset') as HTMLSelectElement).value);
    const [hh, mm] = val.split(':').map(Number);
    const totalMin = hh * 60 + mm + offset * 60;
    const lH = Math.floor(((totalMin % 1440) + 1440) % 1440 / 60);
    const lM = Math.floor(((totalMin % 1440) + 1440) % 1440 % 60);
    const local = `${String(lH).padStart(2,'0')}:${String(lM).padStart(2,'0')}`;
    const div = document.getElementById('result');
    if (div) div.innerHTML = `<strong>${val} UTC = ${local} hora local (UTC${offset >= 0 ? '+' : ''}${offset})</strong>`;
  });
</script>
