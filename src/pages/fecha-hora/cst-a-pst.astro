---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolFormShell from '../../components/ToolFormShell.astro';
import { generateTitle, generateDescription } from '../../utils/seo';

const toolName = 'CST a PST';
const slug = 'cst-a-pst';
const category = 'fecha-hora';
const title = generateTitle(toolName);
const description = generateDescription(toolName, 'convertir hora de CST (América Central) a PST (Pacífico)');
const canonical = `https://calculafacilito.netlify.app/fecha-hora/${slug}/`;
const breadcrumbItems = [
  { name: 'Fecha y hora', url: '/fecha-hora/' },
  { name: toolName }
];
const faqs = [
  { question: '¿Cuánta diferencia hay entre CST y PST?', answer: 'PST (Pacific Standard Time) es 2 horas menos que CST (Central Standard Time). Por ejemplo, las 12:00 CST son las 10:00 PST.' },
  { question: '¿Cambia esto en horario de verano?', answer: 'Durante el horario de verano (DST), la diferencia puede variar. CST=UTC-6, PST=UTC-8 (diferencia de 2 horas).' },
];
---

<ToolLayout title={title} description={description} canonical={canonical} breadcrumbItems={breadcrumbItems} toolName={toolName} toolSlug={slug} category={category} faqs={faqs}>
  <div slot="intro">
    <p>Convierte rápidamente una hora de la zona horaria Central (CST, UTC-6) a Pacífico (PST, UTC-8).</p>
    <h2>Diferencia</h2>
    <p>PST = CST − 2 horas. Si son las 3:00 PM CST, en PST son las 1:00 PM.</p>
  </div>
  <div slot="form">
    <ToolFormShell toolName={toolName}>
      <div slot="inputs">
        <label>Hora en CST (HH:MM):</label>
        <input type="time" id="hora-cst" required />
      </div>
    </ToolFormShell>
  </div>
  <div slot="explanation">
    <h2>¿Cómo funciona?</h2>
    <p>CST es UTC-6 y PST es UTC-8, por lo que PST siempre está 2 horas por detrás de CST.</p>
  </div>
</ToolLayout>

<script>
  const form = document.getElementById('tool-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const valor = (document.getElementById('hora-cst') as HTMLInputElement).value;
      const [hh, mm] = valor.split(':').map(Number);
      let pstH = hh - 2;
      let dia = '';
      if (pstH < 0) { pstH += 24; dia = ' (día anterior)'; }
      const pst = `${String(pstH).padStart(2, '0')}:${String(mm).padStart(2, '0')}`;
      const resultDiv = document.getElementById('result');
      if (resultDiv) resultDiv.innerHTML = `<strong>${valor} CST = ${pst} PST${dia}</strong>`;
    });
  }
</script>
