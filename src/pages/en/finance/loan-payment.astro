---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import ToolFormShell from '../../../components/ToolFormShell.astro';

const lang = 'en';
const toolName = 'Loan Payment Calculator';
const slug = 'cuota-prestamo';
const category = 'finanzas';
const canonical = 'https://calculafacilito.netlify.app/en/finance/loan-payment/';
const breadcrumbItems = [{ name: 'Finance', url: '/en/finance/' }, { name: toolName }];
const faqs = [
  { question: 'What is a monthly loan payment?', answer: 'It is the fixed monthly payment that includes both a portion of the principal and the interest for that period.' },
  { question: 'What is the French amortization system?', answer: 'The most common system: equal monthly payments where you pay more interest at the start and more principal toward the end.' },
];
---

<ToolLayout title={toolName} description="Free loan payment calculator. Find your monthly installment for any loan or mortgage instantly." canonical={canonical} breadcrumbItems={breadcrumbItems} toolName={toolName} toolSlug={slug} category={category} faqs={faqs} lang={lang}>
  <div slot="intro">
    <p>Calculate the monthly payment for any loan or mortgage. Enter the amount, interest rate, and term.</p>
    <h2>Example</h2>
    <p>A $10,000 loan at 6% annual interest over 3 years has a monthly payment of $304.22.</p>
  </div>
  <div slot="form">
    <ToolFormShell toolName={toolName}>
      <div slot="inputs">
        <label>Loan amount:</label>
        <input type="number" id="monto" step="any" placeholder="e.g. 10000" required />
        <label>Annual interest rate (%):</label>
        <input type="number" id="tasa" step="any" placeholder="e.g. 6" required />
        <label>Term (months):</label>
        <input type="number" id="meses" step="1" placeholder="e.g. 36" required />
      </div>
    </ToolFormShell>
  </div>
  <div slot="explanation">
    <h2>How it's calculated</h2>
    <p>Formula: <strong>M = P × [r(1+r)^n] / [(1+r)^n - 1]</strong>, where P = loan amount, r = monthly rate, n = number of months.</p>
  </div>
</ToolLayout>

<script>
  function fmt(n: number): string {
    const c = localStorage.getItem('cf_currency') || 'EUR';
    const syms: Record<string, string> = { EUR:'€', USD:'$', MXN:'$', COP:'$', GBP:'£', ARS:'$', BRL:'R$' };
    const s = syms[c] ?? '€'; const rounded = Math.round(n * 100) / 100;
    return c === 'EUR' ? `${rounded.toFixed(2)} €` : `${s}${rounded.toFixed(2)} ${c}`;
  }
  const form = document.getElementById('tool-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const P = parseFloat((document.getElementById('monto') as HTMLInputElement).value || '0');
      const rate = parseFloat((document.getElementById('tasa') as HTMLInputElement).value || '0');
      const n = parseInt((document.getElementById('meses') as HTMLInputElement).value || '0');
      const r = rate / 100 / 12;
      const rawM = r === 0 ? P / n : P * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
      const monthly = Math.round(rawM * 100) / 100;
      const totalInterest = Math.round((monthly * n - P) * 100) / 100;
      const div = document.getElementById('result');
      if (div) div.innerHTML = `<strong>Monthly payment: ${fmt(monthly)} &nbsp;|&nbsp; Total interest: ${fmt(totalInterest)}</strong>`;
    });
  }
</script>
