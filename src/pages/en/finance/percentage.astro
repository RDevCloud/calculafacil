---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import ToolFormShell from '../../../components/ToolFormShell.astro';

const lang = 'en';
const toolName = 'Percentage Calculator';
const slug = 'porcentaje';
const category = 'finanzas';
const canonical = 'https://calculafacilito.netlify.app/en/finance/percentage/';
const breadcrumbItems = [{ name: 'Finance', url: '/en/finance/' }, { name: toolName }];
const faqs = [
  { question: 'How do I calculate the percentage of a number?', answer: 'To calculate X% of a number, multiply the number by X and divide by 100.' },
  { question: 'What is a percentage?', answer: 'A percentage is a ratio expressed as a fraction of 100. For example, 25% means 25 out of 100.' },
  { question: 'What is this calculator used for?', answer: 'Use it to instantly calculate any percentage — perfect for discounts, taxes, tips, or grade conversions.' },
];
---

<ToolLayout title={toolName} description="Free percentage calculator. Instantly calculate any percentage of any number — discounts, tips, taxes and more." canonical={canonical} breadcrumbItems={breadcrumbItems} toolName={toolName} toolSlug={slug} category={category} faqs={faqs} lang={lang}>
  <div slot="intro">
    <p>Calculate the percentage of any number instantly. Enter the base value and the percentage you want to find.</p>
    <h2>Example</h2>
    <p>To calculate 20% of 150, the result is 30.</p>
  </div>
  <div slot="form">
    <ToolFormShell toolName={toolName}>
      <div slot="inputs">
        <label>Base value:</label>
        <input type="number" id="valor" step="any" placeholder="e.g. 150" required />
        <label>Percentage (%):</label>
        <input type="number" id="porcentaje" step="any" placeholder="e.g. 20" required />
      </div>
    </ToolFormShell>
  </div>
  <div slot="explanation">
    <h2>How to use the percentage calculator</h2>
    <p>Enter the total amount and the percentage you want to calculate. The result appears instantly.</p>
  </div>
</ToolLayout>

<script>
  function fmt(n: number): string {
    const c = localStorage.getItem('cf_currency') || 'EUR';
    const syms: Record<string, string> = { EUR:'€', USD:'$', MXN:'$', COP:'$', GBP:'£', ARS:'$', BRL:'R$' };
    const s = syms[c] ?? '€';
    const r = Math.round(n * 100) / 100;
    return c === 'EUR' ? `${r.toFixed(2)} €` : `${s}${r.toFixed(2)} ${c}`;
  }
  const form = document.getElementById('tool-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const valor = parseFloat((document.getElementById('valor') as HTMLInputElement).value || '0');
      const pct   = parseFloat((document.getElementById('porcentaje') as HTMLInputElement).value || '0');
      const result = (valor * pct) / 100;
      const div = document.getElementById('result');
      if (div) div.innerHTML = `<strong>${pct}% of ${valor} = ${fmt(result)}</strong>`;
    });
  }
</script>
