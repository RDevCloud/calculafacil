---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';

const tools = [
  { title: 'Percentage Calculator', description: 'Calculate percentages, increases and discounts easily.', url: '/en/finance/percentage/', icon: '%' },
  { title: 'Discount Calculator', description: 'Find the final price after applying a discount.', url: '/en/finance/discount/', icon: '🏷️' },
  { title: 'Compound Interest', description: 'Project the growth of your investment.', url: '/en/finance/compound-interest/', icon: '📈' },
  { title: 'Loan Payment Calculator', description: 'Calculate the monthly payment of a loan or mortgage.', url: '/en/finance/loan-payment/', icon: '🏦' },
  { title: 'Monthly Savings Calculator', description: 'Plan how much to save each month to reach your goal.', url: '/en/finance/monthly-savings/', icon: '💰' },
];
---
<BaseLayout title="Finance Calculators" description="Free online finance calculators: percentages, discounts, compound interest, loan payments, and monthly savings.">
  <Breadcrumbs items={[{ name: 'Finance' }]} lang="en" />
  <h1>Finance Calculators</h1>
  <p class="cat-desc">Explore all our free financial calculators and converters.</p>
  <div class="tools-grid">
    {tools.map(tool => <ToolCard {...tool} />)}
  </div>
</BaseLayout>
<style>
  .tools-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px,1fr)); gap: 1.5rem; margin-top: 2rem; }
  .cat-desc { font-size: 1.125rem; color: #4b5563; margin-bottom: 1rem; }
</style>
