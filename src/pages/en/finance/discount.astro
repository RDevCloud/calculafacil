---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import ToolFormShell from '../../../components/ToolFormShell.astro';

const lang = 'en';
const toolName = 'Discount Calculator';
const slug = 'descuento';
const category = 'finanzas';
const canonical = 'https://calculafacilito.netlify.app/en/finance/discount/';
const breadcrumbItems = [{ name: 'Finance', url: '/en/finance/' }, { name: toolName }];
const faqs = [
  { question: 'How do I calculate the discounted price?', answer: 'Multiply the original price by (1 - discount/100). For example, $200 with 15% off = $200 × 0.85 = $170.' },
  { question: 'How much do I save with a discount?', answer: 'Your savings = original price × (discount / 100). With 25% off $200, you save $50.' },
];
---

<ToolLayout title={toolName} description="Free discount calculator. Find the final price and savings after applying any percentage discount." canonical={canonical} breadcrumbItems={breadcrumbItems} toolName={toolName} toolSlug={slug} category={category} faqs={faqs} lang={lang}>
  <div slot="intro">
    <p>Enter the original price and the discount percentage to get the final price and your exact savings.</p>
    <h2>Example</h2>
    <p>A $200 item with 25% off costs $150 — you save $50.</p>
  </div>
  <div slot="form">
    <ToolFormShell toolName={toolName}>
      <div slot="inputs">
        <label>Original price:</label>
        <input type="number" id="precio" step="any" placeholder="e.g. 200" required />
        <label>Discount (%):</label>
        <input type="number" id="descuento" step="any" placeholder="e.g. 25" required />
      </div>
    </ToolFormShell>
  </div>
  <div slot="explanation">
    <h2>How it works</h2>
    <p>Formula: <strong>Final price = Original price × (1 - Discount / 100)</strong>. Savings = Original price − Final price.</p>
  </div>
</ToolLayout>

<script>
  function fmt(n: number): string {
    const c = localStorage.getItem('cf_currency') || 'EUR';
    const syms: Record<string, string> = { EUR:'€', USD:'$', MXN:'$', COP:'$', GBP:'£', ARS:'$', BRL:'R$' };
    const s = syms[c] ?? '€'; const r = Math.round(n * 100) / 100;
    return c === 'EUR' ? `${r.toFixed(2)} €` : `${s}${r.toFixed(2)} ${c}`;
  }
  const form = document.getElementById('tool-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const precio = parseFloat((document.getElementById('precio') as HTMLInputElement).value || '0');
      const disc   = parseFloat((document.getElementById('descuento') as HTMLInputElement).value || '0');
      const final  = precio * (1 - disc / 100);
      const saved  = precio - final;
      const div = document.getElementById('result');
      if (div) div.innerHTML = `<strong>Final price: ${fmt(final)} &nbsp;|&nbsp; Savings: ${fmt(saved)}</strong>`;
    });
  }
</script>
