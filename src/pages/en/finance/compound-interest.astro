---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import ToolFormShell from '../../../components/ToolFormShell.astro';

const lang = 'en';
const toolName = 'Compound Interest Calculator';
const slug = 'interes-compuesto';
const category = 'finanzas';
const canonical = 'https://calculafacilito.netlify.app/en/finance/compound-interest/';
const breadcrumbItems = [{ name: 'Finance', url: '/en/finance/' }, { name: toolName }];
const faqs = [
  { question: 'What is compound interest?', answer: 'Compound interest is interest calculated on the initial principal plus all previously accumulated interest. It makes your money grow faster over time.' },
  { question: 'What is the compound interest formula?', answer: 'A = P × (1 + r/n)^(n×t), where P = principal, r = annual rate, n = compounding periods per year, t = years.' },
];
---

<ToolLayout title={toolName} description="Free compound interest calculator. Project the growth of your investment or savings with compound interest." canonical={canonical} breadcrumbItems={breadcrumbItems} toolName={toolName} toolSlug={slug} category={category} faqs={faqs} lang={lang}>
  <div slot="intro">
    <p>Calculate how much your investment will grow with compound interest. Enter the principal, annual rate, and time period.</p>
    <h2>Example</h2>
    <p>$1,000 at 5% annual interest for 10 years = $1,628.89</p>
  </div>
  <div slot="form">
    <ToolFormShell toolName={toolName}>
      <div slot="inputs">
        <label>Initial capital:</label>
        <input type="number" id="capital" step="any" placeholder="e.g. 1000" required />
        <label>Annual interest rate (%):</label>
        <input type="number" id="tasa" step="any" placeholder="e.g. 5" required />
        <label>Years:</label>
        <input type="number" id="anos" step="1" placeholder="e.g. 10" required />
        <label>Compounding frequency:</label>
        <select id="n">
          <option value="12">Monthly (12×/year)</option>
          <option value="4">Quarterly (4×/year)</option>
          <option value="2">Semi-annually (2×/year)</option>
          <option value="1">Annually (1×/year)</option>
        </select>
      </div>
    </ToolFormShell>
  </div>
  <div slot="explanation">
    <h2>How it works</h2>
    <p>Formula: <strong>A = P × (1 + r/n)^(n×t)</strong>. The power of compound interest is that interest earns interest over time.</p>
  </div>
</ToolLayout>

<script>
  function fmt(n: number): string {
    const c = localStorage.getItem('cf_currency') || 'EUR';
    const syms: Record<string, string> = { EUR:'€', USD:'$', MXN:'$', COP:'$', GBP:'£', ARS:'$', BRL:'R$' };
    const s = syms[c] ?? '€'; const r = Math.round(n * 100) / 100;
    return c === 'EUR' ? `${r.toFixed(2)} €` : `${s}${r.toFixed(2)} ${c}`;
  }
  const form = document.getElementById('tool-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const P = parseFloat((document.getElementById('capital') as HTMLInputElement).value || '0');
      const r = parseFloat((document.getElementById('tasa') as HTMLInputElement).value || '0') / 100;
      const t = parseFloat((document.getElementById('anos') as HTMLInputElement).value || '0');
      const n = parseFloat((document.getElementById('n') as HTMLSelectElement).value);
      const A = P * Math.pow(1 + r / n, n * t);
      const gain = A - P;
      const div = document.getElementById('result');
      if (div) div.innerHTML = `<strong>Final amount: ${fmt(A)} &nbsp;|&nbsp; Earnings: ${fmt(gain)}</strong>`;
    });
  }
</script>
