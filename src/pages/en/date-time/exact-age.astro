---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import ToolFormShell from '../../../components/ToolFormShell.astro';

const lang = 'en';
const toolName = 'Exact Age Calculator';
const slug = 'edad-exacta';
const category = 'fecha-hora';
const canonical = 'https://calculafacilito.netlify.app/en/date-time/exact-age/';
const breadcrumbItems = [{ name: 'Date & Time', url: '/en/date-time/' }, { name: toolName }];
const faqs = [
  { question: 'How do I calculate my exact age?', answer: 'Enter your birth date and the calculator will tell you your exact age in years, months, and days as of today.' },
  { question: 'How many days until my next birthday?', answer: 'The calculator also shows the number of days remaining until your next birthday.' },
];
---

<ToolLayout title={toolName} description="Free age calculator. Find your exact age in years, months, and days from your date of birth." canonical={canonical} breadcrumbItems={breadcrumbItems} toolName={toolName} toolSlug={slug} category={category} faqs={faqs} lang={lang}>
  <div slot="intro">
    <p>Calculate your exact age in years, months, and days from your date of birth.</p>
  </div>
  <div slot="form">
    <ToolFormShell toolName={toolName}>
      <div slot="inputs">
        <label>Date of birth:</label>
        <input type="date" id="nacimiento" required />
      </div>
    </ToolFormShell>
  </div>
  <div slot="explanation">
    <h2>How it works</h2>
    <p>Compares your date of birth to today's date and calculates your exact age including years, months, and remaining days.</p>
  </div>
</ToolLayout>

<script>
  const form = document.getElementById('tool-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const nac = new Date((document.getElementById('nacimiento') as HTMLInputElement).value);
      const hoy = new Date();
      const div = document.getElementById('result');
      if (!div || isNaN(nac.getTime())) return;
      let years = hoy.getFullYear() - nac.getFullYear();
      let months = hoy.getMonth() - nac.getMonth();
      let days = hoy.getDate() - nac.getDate();
      if (days < 0) { months--; days += new Date(hoy.getFullYear(), hoy.getMonth(), 0).getDate(); }
      if (months < 0) { years--; months += 12; }
      const bday = new Date(hoy.getFullYear(), nac.getMonth(), nac.getDate());
      if (bday < hoy) bday.setFullYear(hoy.getFullYear() + 1);
      const daysLeft = Math.round((bday.getTime() - hoy.getTime()) / (1000 * 60 * 60 * 24));
      div.innerHTML = `<strong>${years} years, ${months} months and ${days} days</strong><br><small>Next birthday in ${daysLeft} day(s) 🎂</small>`;
    });
  }
</script>
