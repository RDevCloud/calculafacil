---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import ToolFormShell from '../../../components/ToolFormShell.astro';

const lang = 'en';
const toolName = 'Days Between Dates';
const slug = 'dias-entre-fechas';
const category = 'fecha-hora';
const canonical = 'https://calculafacilito.netlify.app/en/date-time/days-between-dates/';
const breadcrumbItems = [{ name: 'Date & Time', url: '/en/date-time/' }, { name: toolName }];
const faqs = [
  { question: 'How do I calculate days between two dates?', answer: 'Subtract the start date from the end date. The result is the number of days between them.' },
  { question: 'What can I use this for?', answer: 'Useful for calculating deadlines, event countdowns, project durations, or billing periods.' },
];
---

<ToolLayout title={toolName} description="Free date difference calculator. Find exactly how many days, weeks, or months between two dates." canonical={canonical} breadcrumbItems={breadcrumbItems} toolName={toolName} toolSlug={slug} category={category} faqs={faqs} lang={lang}>
  <div slot="intro">
    <p>Calculate exactly how many days, weeks, or months are between two dates.</p>
  </div>
  <div slot="form">
    <ToolFormShell toolName={toolName}>
      <div slot="inputs">
        <label>Start date:</label>
        <input type="date" id="fecha1" required />
        <label>End date:</label>
        <input type="date" id="fecha2" required />
      </div>
    </ToolFormShell>
  </div>
  <div slot="explanation">
    <h2>How it works</h2>
    <p>Calculates the exact difference between two dates in days, weeks, and approximate months.</p>
  </div>
</ToolLayout>

<script>
  const form = document.getElementById('tool-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const d1 = new Date((document.getElementById('fecha1') as HTMLInputElement).value);
      const d2 = new Date((document.getElementById('fecha2') as HTMLInputElement).value);
      const diffMs = d2.getTime() - d1.getTime();
      const days  = Math.round(diffMs / (1000 * 60 * 60 * 24));
      const weeks = (days / 7).toFixed(1);
      const months = (days / 30.44).toFixed(1);
      const div = document.getElementById('result');
      if (!div) return;
      if (isNaN(days)) { div.innerHTML = `<strong>Please enter both dates.</strong>`; return; }
      if (days < 0) { div.innerHTML = `<strong>End date must be after start date.</strong>`; return; }
      div.innerHTML = `<strong>${Math.abs(days)} days &nbsp;|&nbsp; ${weeks} weeks &nbsp;|&nbsp; ${months} months</strong>`;
    });
  }
</script>
