---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import ToolFormShell from '../../../components/ToolFormShell.astro';

const lang = 'en';
const toolName = 'CST to PST Converter';
const slug = 'cst-a-pst';
const category = 'fecha-hora';
const canonical = 'https://calculafacilito.netlify.app/en/date-time/cst-to-pst/';
const breadcrumbItems = [{ name: 'Date & Time', url: '/en/date-time/' }, { name: toolName }];
const faqs = [
  { question: 'How many hours difference between CST and PST?', answer: 'PST (Pacific Standard Time) is 2 hours behind CST (Central Standard Time). For example, 12:00 PM CST = 10:00 AM PST.' },
  { question: 'Does this change with Daylight Saving Time?', answer: 'During DST the difference may vary. CST = UTC-6, PST = UTC-8 (2-hour difference standard time).' },
];
---

<ToolLayout title={toolName} description="Free CST to PST time converter. Instantly convert Central Standard Time to Pacific Standard Time." canonical={canonical} breadcrumbItems={breadcrumbItems} toolName={toolName} toolSlug={slug} category={category} faqs={faqs} lang={lang}>
  <div slot="intro">
    <p>Quickly convert a time from Central Time (CST, UTC-6) to Pacific Time (PST, UTC-8).</p>
    <h2>Difference</h2>
    <p>PST = CST − 2 hours. If it's 3:00 PM CST, it's 1:00 PM PST.</p>
  </div>
  <div slot="form">
    <ToolFormShell toolName={toolName}>
      <div slot="inputs">
        <label>Time in CST (HH:MM):</label>
        <input type="time" id="hora-cst" required />
      </div>
    </ToolFormShell>
  </div>
  <div slot="explanation">
    <h2>How it works</h2>
    <p>CST is UTC-6 and PST is UTC-8, so PST is always 2 hours behind CST.</p>
  </div>
</ToolLayout>

<script>
  const form = document.getElementById('tool-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const val = (document.getElementById('hora-cst') as HTMLInputElement).value;
      const [hh, mm] = val.split(':').map(Number);
      let pstH = hh - 2;
      let note = '';
      if (pstH < 0) { pstH += 24; note = ' (previous day)'; }
      const pst = `${String(pstH).padStart(2,'0')}:${String(mm).padStart(2,'0')}`;
      const div = document.getElementById('result');
      if (div) div.innerHTML = `<strong>${val} CST = ${pst} PST${note}</strong>`;
    });
  }
</script>
