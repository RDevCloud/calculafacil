---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SearchBar from '../../components/SearchBar.astro';
import ToolCard from '../../components/ToolCard.astro';
import CategoryCard from '../../components/CategoryCard.astro';
import AdSlot from '../../components/AdSlot.astro';

const popularTools = [
  { title: 'Percentage Calculator', description: 'Calculate percentages, increases and discounts easily.', url: '/en/finance/percentage/', icon: '%' },
  { title: 'Discount Calculator', description: 'Find the final price after applying a discount.', url: '/en/finance/discount/', icon: '🏷️' },
  { title: 'Compound Interest', description: 'Project the growth of your investment.', url: '/en/finance/compound-interest/', icon: '📈' },
  { title: 'Loan Payment', description: 'Calculate the monthly payment of a loan.', url: '/en/finance/loan-payment/', icon: '🏦' },
  { title: 'Days Between Dates', description: 'Calculate days, weeks or months between two dates.', url: '/en/date-time/days-between-dates/', icon: '📅' },
  { title: 'Word Counter', description: 'Count words, characters and sentences in your text.', url: '/en/utilities/word-counter/', icon: '📝' },
];

const categories = [
  { name: 'Finance', slug: 'finance', description: 'Percentage, discount, loans, compound interest and savings calculators.' },
  { name: 'Date & Time', slug: 'date-time', description: 'Date converters, age calculators and timezone tools.' },
  { name: 'Utilities', slug: 'utilities', description: 'Practical tools like word counter and more.' },
];
---

<BaseLayout title="EasyCalc" description="Free online calculators. Percentages, finance, dates, time zones and more — fast and precise tools.">
  <section class="hero">
    <h1>EasyCalc</h1>
    <p>Fast, precise online tools — no signup required</p>
    <SearchBar />
  </section>

  <AdSlot format="banner" />

  <section class="popular-tools">
    <h2>Most popular tools</h2>
    <div class="tools-grid">
      {popularTools.map(tool => <ToolCard {...tool} />)}
    </div>
  </section>

  <section class="categories">
    <h2>Categories</h2>
    <div class="categories-grid">
      {categories.map(cat => (
        <a href={`/en/${cat.slug}/`} class="category-card">
          <h3>{cat.name}</h3>
          <p>{cat.description}</p>
          <span class="cat-link">Browse tools →</span>
        </a>
      ))}
    </div>
  </section>

  <AdSlot format="horizontal" />
</BaseLayout>

<style>
  .hero { text-align: center; padding: 2rem 1rem; }
  .hero h1 { font-size: 2.5rem; margin-bottom: 1rem; }
  .tools-grid, .categories-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1.5rem; margin: 2rem 0; }
  .category-card { display: block; background: linear-gradient(135deg,#f0f9ff,#e0f2fe); border-radius:1rem; padding:1.5rem; text-decoration:none; color:#1f2937; border:1px solid #bae6fd; transition: transform .2s, box-shadow .2s; }
  .category-card:hover { transform: translateY(-4px); box-shadow: 0 10px 25px -5px rgba(37,99,235,.15); }
  .category-card h3 { margin-bottom:.5rem; }
  .category-card p { font-size:.875rem; color:#6b7280; margin-bottom:1rem; }
  .cat-link { font-weight:600; color:#2563eb; }
</style>
