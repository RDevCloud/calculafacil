---
import ToolLayout from '../../../layouts/ToolLayout.astro';
import ToolFormShell from '../../../components/ToolFormShell.astro';

const lang = 'en';
const toolName = 'Word Counter';
const slug = 'contador-palabras';
const category = 'utilidades';
const canonical = 'https://calculafacilito.netlify.app/en/utilities/word-counter/';
const breadcrumbItems = [{ name: 'Utilities', url: '/en/utilities/' }, { name: toolName }];
const faqs = [
  { question: 'What is a word counter used for?', answer: 'It helps when writing content with word limits — essays, SEO articles, tweets, academic summaries, or job application cover letters.' },
  { question: 'How are characters counted?', answer: 'You can see characters with or without spaces. Characters without spaces are useful for SMS limits or social media bios.' },
];
---

<ToolLayout title={toolName} description="Free word counter. Instantly count words, characters, sentences, and paragraphs in any text." canonical={canonical} breadcrumbItems={breadcrumbItems} toolName={toolName} toolSlug={slug} category={category} faqs={faqs} lang={lang}>
  <div slot="intro">
    <p>Paste or type your text to instantly count words, characters, sentences, and paragraphs.</p>
  </div>
  <div slot="form">
    <ToolFormShell toolName={toolName}>
      <div slot="inputs">
        <label>Your text:</label>
        <textarea id="texto" rows="6" placeholder="Write or paste your text here..." style="width:100%;padding:0.6rem 0.8rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:1rem;resize:vertical;box-sizing:border-box;font-family:inherit;margin-bottom:1rem;"></textarea>
      </div>
    </ToolFormShell>
  </div>
  <div slot="explanation">
    <h2>What does this tool count?</h2>
    <p>Words, total characters, characters without spaces, sentences, and paragraphs in any text.</p>
  </div>
</ToolLayout>

<script>
  const form = document.getElementById('tool-form') as HTMLFormElement;
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const text = ((document.getElementById('texto') as HTMLTextAreaElement).value || '').trim();
      const words = text ? text.split(/\s+/).filter(w => w.length > 0).length : 0;
      const chars = text.length;
      const charsNoSpaces = text.replace(/\s/g,'').length;
      const sentences = text ? text.split(/[.!?]+/).filter(s => s.trim().length > 0).length : 0;
      const paragraphs = text ? text.split(/\n+/).filter(p => p.trim().length > 0).length : 0;
      const div = document.getElementById('result');
      if (div) div.innerHTML = `
        <strong>Words: ${words}</strong> &nbsp;|&nbsp;
        <strong>Characters: ${chars}</strong> &nbsp;|&nbsp;
        <strong>No spaces: ${charsNoSpaces}</strong><br>
        <small>Sentences: ${sentences} &nbsp;|&nbsp; Paragraphs: ${paragraphs}</small>
      `;
    });
  }
</script>
