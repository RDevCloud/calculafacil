---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';

const tools = [
  { title: 'Word Counter', description: 'Count words, characters and sentences in your text.', url: '/en/utilities/word-counter/', icon: '📝' },
];
---
<BaseLayout title="Online Utilities" description="Free online utilities: word counter, character counter, and more practical tools.">
  <Breadcrumbs items={[{ name: 'Utilities' }]} lang="en" />
  <h1>Online Utilities</h1>
  <p class="cat-desc">Explore all our free utility tools.</p>
  <div class="tools-grid">
    {tools.map(tool => <ToolCard {...tool} />)}
  </div>
</BaseLayout>
<style>
  .tools-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px,1fr)); gap: 1.5rem; margin-top: 2rem; }
  .cat-desc { font-size: 1.125rem; color: #4b5563; margin-bottom: 1rem; }
</style>
