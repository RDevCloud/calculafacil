---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolFormShell from '../../components/ToolFormShell.astro';
import { generateTitle, generateDescription } from '../../utils/seo';

const toolName = 'Contador de palabras';
const slug = 'contador-palabras';
const category = 'utilidades';
const title = generateTitle(toolName);
const description = generateDescription(toolName, 'contar palabras, caracteres y oraciones en un texto');
const canonical = `https://calculafacilito.netlify.app/utilidades/${slug}/`;
const breadcrumbItems = [
  { name: 'Utilidades', url: '/utilidades/' },
  { name: toolName }
];
const faqs = [
  { question: '¿Para qué sirve el contador de palabras?', answer: 'Es útil para redactar textos con límite de palabras, como ensayos, artículos SEO, tweets o resúmenes académicos.' },
  { question: '¿Cómo cuenta los caracteres?', answer: 'Puedes ver caracteres con o sin espacios. Los caracteres sin espacios son útiles para límites de SMS o redes sociales.' },
];
---

<ToolLayout title={title} description={description} canonical={canonical} breadcrumbItems={breadcrumbItems} toolName={toolName} toolSlug={slug} category={category} faqs={faqs}>
  <div slot="intro">
    <p>Pega o escribe tu texto para contar palabras, caracteres, oraciones y párrafos al instante.</p>
  </div>
  <div slot="form">
    <ToolFormShell toolName={toolName}>
      <div slot="inputs">
        <label>Tu texto:</label>
        <textarea id="texto" rows="6" placeholder="Escribe o pega tu texto aquí..." style="width:100%;padding:0.6rem 0.8rem;border:1px solid #d1d5db;border-radius:0.5rem;font-size:1rem;resize:vertical;box-sizing:border-box;font-family:inherit;margin-bottom:1rem;"></textarea>
      </div>
    </ToolFormShell>
  </div>
  <div slot="explanation">
    <h2>¿Qué cuenta esta herramienta?</h2>
    <p>Cuenta palabras, caracteres totales, caracteres sin espacios, oraciones y párrafos de cualquier texto.</p>
  </div>
</ToolLayout>

<script>
  document.getElementById('calc-btn')?.addEventListener('click', () => {
    const text = ((document.getElementById('texto') as HTMLTextAreaElement).value || '').trim();
    const words = text ? text.split(/\s+/).filter((w: string) => w.length > 0).length : 0;
    const chars = text.length;
    const charsNoSpaces = text.replace(/\s/g,'').length;
    const sentences = text ? text.split(/[.!?]+/).filter((s: string) => s.trim().length > 0).length : 0;
    const paragraphs = text ? text.split(/\n+/).filter((p: string) => p.trim().length > 0).length : 0;
    const div = document.getElementById('result');
    if (div) div.innerHTML = `<strong>Palabras: ${words}</strong> &nbsp;|&nbsp; <strong>Caracteres: ${chars}</strong> &nbsp;|&nbsp; <strong>Sin espacios: ${charsNoSpaces}</strong><br><small>Oraciones: ${sentences} &nbsp;|&nbsp; Párrafos: ${paragraphs}</small>`;
  });
</script>
