---
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolFormShell from '../../components/ToolFormShell.astro';
import { generateTitle, generateDescription } from '../../utils/seo';

const toolName = 'Ahorro mensual';
const slug = 'ahorro-mensual';
const category = 'finanzas';
const title = generateTitle(toolName);
const description = generateDescription(toolName, 'cuánto ahorrar cada mes para alcanzar tu meta financiera');
const canonical = `https://calculafacilito.netlify.app/finanzas/${slug}/`;
const breadcrumbItems = [
  { name: 'Finanzas', url: '/finanzas/' },
  { name: toolName }
];
const faqs = [
  { question: '¿Cómo calculo cuánto ahorrar al mes?', answer: 'Divide tu meta financiera entre el número de meses que tienes disponibles. Si ya tienes un ahorro inicial, réstalo primero.' },
  { question: '¿Por qué es importante el ahorro mensual?', answer: 'El ahorro constante te permite alcanzar metas financieras sin depender de ingresos extraordinarios.' },
];
---

<ToolLayout title={title} description={description} canonical={canonical} breadcrumbItems={breadcrumbItems} toolName={toolName} toolSlug={slug} category={category} faqs={faqs}>
  <div slot="intro">
    <p>Descubre cuánto debes ahorrar cada mes para alcanzar tu meta en el tiempo deseado.</p>
    <h2>Ejemplo</h2>
    <p>Para ahorrar 3,000 € en 12 meses partiendo de 0 €, necesitas ahorrar 250 € al mes.</p>
  </div>
  <div slot="form">
    <ToolFormShell toolName={toolName}>
      <div slot="inputs">
        <label>Meta de ahorro (€):</label>
        <input type="number" id="meta" step="any" placeholder="Ej: 3000" required />
        <label>Ahorro actual (€):</label>
        <input type="number" id="actual" step="any" placeholder="Ej: 0" value="0" />
        <label>Plazo (meses):</label>
        <input type="number" id="meses" step="1" placeholder="Ej: 12" required />
      </div>
    </ToolFormShell>
  </div>
  <div slot="explanation">
    <h2>¿Cómo funciona?</h2>
    <p>Fórmula: <strong>Ahorro mensual = (Meta − Ahorro actual) ÷ Meses</strong>. Simple y directo.</p>
  </div>
</ToolLayout>

<script>
  function fmt(n: number): string {
    const c = localStorage.getItem('cf_currency') || 'EUR';
    const syms: Record<string, string> = { EUR:'€', USD:'$', MXN:'$', COP:'$', GBP:'£', ARS:'$', BRL:'R$' };
    const s = syms[c] ?? '€';
    const r = Math.round(n * 100) / 100;
    return c === 'EUR' ? `${r.toFixed(2)} €` : `${s}${r.toFixed(2)} ${c}`;
  }
  document.getElementById('calc-btn')?.addEventListener('click', () => {
    const meta    = parseFloat((document.getElementById('meta') as HTMLInputElement).value || '0');
    const actual  = parseFloat((document.getElementById('actual') as HTMLInputElement).value || '0');
    const meses   = parseFloat((document.getElementById('meses') as HTMLInputElement).value || '1');
    const monthly = (meta - actual) / meses;
    const div = document.getElementById('result');
    if (!div) return;
    if (monthly <= 0) { div.innerHTML = '<strong>🎉 ¡Ya alcanzaste tu meta!</strong>'; return; }
    div.innerHTML = `<strong>Necesitas ahorrar: ${fmt(monthly)} / mes</strong>`;
  });
</script>
