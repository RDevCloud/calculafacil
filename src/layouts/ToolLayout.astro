---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import AdSlot from '../components/AdSlot.astro';
import RelatedTools from '../components/RelatedTools.astro';
import FAQ from '../components/FAQ.astro';
import type { FAQItem } from '../components/FAQ.astro';
import { getToolsByCategory } from '../data/tools';
import '../styles/tool.css';

export interface Props {
  title: string;
  description: string;
  canonical: string;
  breadcrumbItems: { name: string; url?: string }[];
  toolName: string;
  toolSlug: string;
  category: string;
  faqs: FAQItem[];
  lang?: string;
}
const { title, description, canonical, breadcrumbItems, toolName, toolSlug, category, faqs, lang = 'es' } = Astro.props;
const relatedTools = getToolsByCategory(category).filter(t => t.slug !== toolSlug).slice(0, 3);
---

<BaseLayout title={title} description={description} canonical={canonical}>
  <div class="tool-layout">
    <Breadcrumbs items={breadcrumbItems} lang={lang} />
    <div class="tool-main">
      <div class="tool-content">
        <h1>{toolName}</h1>
        <slot name="intro" />
        <slot name="form" />
        <slot name="explanation" />
        <FAQ faqs={faqs} lang={lang} />
        <RelatedTools tools={relatedTools} currentSlug={toolSlug} lang={lang} />
      </div>
      <aside class="tool-sidebar">
        <AdSlot format="vertical" />
        <AdSlot format="horizontal" />
      </aside>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .tool-layout { max-width: 1280px; margin: 0 auto; }
  .tool-main { display: grid; grid-template-columns: 1fr 300px; gap: 2rem; }
  @media (max-width: 768px) { .tool-main { grid-template-columns: 1fr; } .tool-sidebar { order: 2; } }
</style>