---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { urlToEn, urlToEs } from '../i18n/url-map';
import '../styles/global.css';

const BASE = 'https://calculafacilito.netlify.app';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
}
const { title, description, canonical, ogImage } = Astro.props;
const siteTitle = 'CalculaFácil';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;

// Auto-generate hreflang URLs from current path
const path = Astro.url.pathname;
const isEn = path.startsWith('/en/');
const esPath = isEn ? (urlToEs[path] ?? '/') : path;
const enPath = isEn ? path : (urlToEn[path] ?? '/en/');
const esHref = `${BASE}${esPath}`;
const enHref = `${BASE}${enPath}`;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical || Astro.url.href} />
    <meta name="robots" content="index, follow" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage || '/og/default.jpg'} />
    <meta name="twitter:card" content="summary_large_image" />
    <!-- hreflang for bilingual SEO -->
    <link rel="alternate" hreflang="es" href={esHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="x-default" href={esHref} />
    <!-- Google Consent Mode v2: default denied until user accepts -->
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(...args: any[]) { window.dataLayer.push(args); }
      const _consent = localStorage.getItem('cf_consent');
      const _val = _consent === 'granted' ? 'granted' : 'denied';
      (window as any).gtag = gtag;
      gtag('consent', 'default', {
        ad_storage: _val,
        ad_user_data: _val,
        ad_personalization: _val,
        analytics_storage: _val,
      });
    </script>
    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-6695699939765081" crossorigin="anonymous"></script>
    <slot name="head" />
  </head>
  <body>
    <Header />
    <main class="main-content">
      <div class="container">
        <slot />
      </div>
    </main>
    <Footer />
    <!-- Google CMP aparecerá aquí automáticamente -->
  </body>
</html>

<style>
  .main-content { min-height: 60vh; padding: 2rem 0; }
</style>